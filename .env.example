# Hercules — Environment Configuration
# Copy this file to .env and adjust values as needed.

# Metasploit RPC password (used by msfrpcd and pymetasploit3 client)
MSF_PASSWORD=hercules

# Skip Metasploit setup (PostgreSQL, msfdb, msfrpcd) for faster startup
SKIP_METASPLOIT=false

# Keep the Kali container after server shutdown (for debugging)
PRESERVE_CONTAINER=false

# Use --privileged instead of minimal capabilities (NET_ADMIN, NET_RAW)
USE_PRIVILEGED=false

# Tool install mode: "minimal" (only essentials) | "headless" (kali-linux-headless) | "large" (kali-linux-large)
TOOL_INSTALL_MODE=minimal

# Concurrency limits
MAX_CONCURRENT_HEAVY=3
MAX_CONCURRENT_LIGHT=10

# Target safety controls (comma-separated, empty = allow all)
ALLOWED_TARGETS=
BLOCKED_TARGETS=

# Container resource limits (0 = unlimited)
CONTAINER_CPU_LIMIT=0
CONTAINER_MEM_LIMIT=0

# Default command timeout in seconds
DEFAULT_TIMEOUT=300
